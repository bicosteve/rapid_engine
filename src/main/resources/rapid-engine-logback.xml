<?xml version="1.0" encoding="UTF-8" ?>
<configuration>
    <!-- Properties-->
    <property name="APP_NAME" value="rapid-engine"/>

    <!--Set Log Pattern for the human-readable dev console -->
    <property
            name="CONSOLE_PATTERN"
            value="%d{yyyy-MM-dd HH:mm:ss} | %-5level | %logger{25} | %M line %L | %msg%n"
    />

    <!--
        NOTE: Appenders are defined inside their matching <springProfile> blocks
        below. Defining a profile-specific appender at the top level (where it is
        only referenced inside one profile) makes Logback emit a harmless
        "Appender named [...] not referenced. Skipping further processing." warning
        whenever that profile is inactive. Scoping each appender to its profile
        avoids the warning entirely.
    -->

    <!-- ─────────────────────────────────────────── -->

    <!-- LOGGER LEVELS -->
    <!-- ─────────────────────────────────────────── -->

    <!-- Spring framework — reduces Spring framework noise -->
    <logger name="org.springframework" level="WARN"/>

    <!--- Show SQL/JDBC related info -->
    <logger name="org.springframework.jdbc" level="INFO"/>

    <!-- Hikari connection pool -->
    <logger name="com.zaxxer.hikari" level="WARN"/>

    <!-- RabbitMQ -->
    <logger name="org.springframework.amqp" level="WARN"/>

    <!-- Spring Profiles -->
    <springProfile name="dev">
        <!--Console Appender (human-readable, used in dev)-->
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>${CONSOLE_PATTERN}</pattern>
            </encoder>
        </appender>

        <!--For dev profile, log human-readable to console only-->
        <root level="DEBUG">

            <appender-ref ref="CONSOLE"/>
        </root>

        <!--rapid-engine logs on dev profile -->
        <logger name="com.bixx.rapid_engine" level="DEBUG" additivity="false">
            <appender-ref ref="CONSOLE"/>
        </logger>
    </springProfile>

    <springProfile name="prod">
        <!--
            JSON Console Appender (used in prod).
            Emits one structured JSON log line per event to stdout. Docker captures
            stdout and the Grafana Alloy/Promtail agent ships it to Grafana Cloud Loki,
            where it is searchable by the indexed fields below. No log files are written
            to disk in prod, so nothing needs to be tailed on the VM.
        -->
        <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <includeMdcKeyName>traceId</includeMdcKeyName>
                <customFields>{"app":"rapid-engine","env":"prod"}</customFields>
            </encoder>
        </appender>

        <!--
            For prod, log structured JSON to stdout ONLY.
            The Grafana Alloy agent on the VM ships stdout to Grafana Cloud Loki.
            No files are written to the container/host filesystem.
        -->
        <root level="INFO">

            <appender-ref ref="JSON_CONSOLE"/>
        </root>

        <logger name="com.bixx.rapid_engine" level="INFO" additivity="false">
            <appender-ref ref="JSON_CONSOLE"/>
        </logger>
    </springProfile>

</configuration>
